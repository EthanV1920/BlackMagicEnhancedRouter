{
  "name": "blackmagic-enhanced-router",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -k -n server,web -c blue,green \"pnpm --filter @blackmagic-enhanced-router/server dev\" \"pnpm --filter @blackmagic-enhanced-router/web dev\"",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}

